# ══════════════════════════════════════════════════════════════════════════════
#  Personal Automation Hub — Environment Configuration
#
#  HOW TO USE:
#    cp .env.example .env
#    nano .env        ← fill in every value marked with  ← REQUIRED
#    docker compose up -d --build
# ══════════════════════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=Personal Automation Hub
APP_HOST=0.0.0.0
APP_PORT=8000

# Generate: python -c "import secrets; print(secrets.token_hex(32))"
APP_API_KEY=change-me-generate-a-strong-key       # ← REQUIRED

# ── Database ──────────────────────────────────────────────────────────────────
# docker-compose OVERRIDES this automatically with the Postgres service URL.
# You only need to set DATABASE_URL if you run outside Docker (e.g., local dev).
DATABASE_URL=sqlite:///./automation_hub.db

# Strong password for the Postgres container. Use letters+numbers, no spaces.
POSTGRES_PASSWORD=change-me-strong-password       # ← REQUIRED

# ── Scheduler ────────────────────────────────────────────────────────────────
SCHEDULER_POLL_SECONDS=30

# ── Daily Digest (optional) ──────────────────────────────────────────────────
DAILY_SUMMARY_ENABLED=false
DAILY_SUMMARY_TIME_UTC=19:00
DAILY_SUMMARY_CHANNEL=telegram
DAILY_SUMMARY_TARGET=                             # Your Telegram chat ID (same as TELEGRAM_CHAT_ID)

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Get from @BotFather → /newbot
TELEGRAM_BOT_TOKEN=                               # ← REQUIRED
# Your personal Telegram user ID — get it by messaging your bot with /id
TELEGRAM_CHAT_ID=                                 # ← REQUIRED
TELEGRAM_BOT_POLLING_ENABLED=true
TELEGRAM_BOT_POLL_TIMEOUT_SECONDS=20

# Webhook mode (advanced — leave blank for polling)
# TELEGRAM_WEBHOOK_URL=https://hub.kcpd.top/telegram/webhook
# TELEGRAM_WEBHOOK_SECRET=   # python -c "import secrets; print(secrets.token_hex(32))"

# ── Telegram Mini App ─────────────────────────────────────────────────────────
# Full public HTTPS URL to the /miniapp endpoint.
# After deploy: your bot's Menu Button auto-registers to this URL on startup.
MINIAPP_URL=https://hub.kcpd.top/miniapp          # ← Set to your domain

# ── Media Storage (Telegram Inbox files) ─────────────────────────────────────
# local: store/fetch in ./media on this server
# r2: durable object storage in Cloudflare R2 + local cache for hot files
MEDIA_STORAGE_BACKEND=local
MEDIA_CACHE_DIR=media

# Cloudflare R2 (required only when MEDIA_STORAGE_BACKEND=r2)
# Dashboard → R2 → Manage R2 API Tokens
MEDIA_R2_ACCOUNT_ID=
MEDIA_R2_BUCKET=
MEDIA_R2_ACCESS_KEY_ID=
MEDIA_R2_SECRET_ACCESS_KEY=
# Optional public CDN/base URL, e.g. https://cdn.example.com
MEDIA_R2_PUBLIC_BASE_URL=

# ── Notes Encryption ─────────────────────────────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# WARNING: Changing this key makes all existing notes unreadable. Back it up!
NOTES_ENCRYPTION_KEY=                             # ← REQUIRED

# ── Email Channel (optional) ─────────────────────────────────────────────────
# Fill to enable sending reminders via email.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_USE_TLS=true

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=200/minute
